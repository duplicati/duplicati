<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Duplicati.Proprietary.DiskImage</RootNamespace>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Duplicati\Library\Interface\Duplicati.Library.Interface.csproj" />
    <ProjectReference Include="..\..\Duplicati\Library\Common\Duplicati.Library.Common.csproj" />
    <ProjectReference Include="..\..\Duplicati\Library\Utility\Duplicati.Library.Utility.csproj" />
    <ProjectReference Include="..\..\Duplicati\Library\Localization\Duplicati.Library.Localization.csproj" />
    <ProjectReference Include="..\..\Duplicati\Library\Logging\Duplicati.Library.Logging.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Vanara.PInvoke.Kernel32" Version="5.0.0" />
    <PackageReference Include="Vanara.PInvoke.Shared" Version="5.0.0" />
    <ContentWithTargetPath Include="$(ProjectDir)NativeLibraryWrappers/libSystem_wrapper.dylib">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>runtimes/osx/native/libSystem_wrapper.dylib</TargetPath>
    </ContentWithTargetPath>
  </ItemGroup>

  <Target Name="CompileNativeLibraryLinux" AfterTargets="Build" Condition="$([MSBuild]::IsOSPlatform('linux'))">
    <!-- Compile the shared library directly to the project directory -->
    <Exec Command="gcc -shared -fPIC -o $(OutputPath)libc_wrapper.so $(ProjectDir)Disk/linux_libc_wrapper.c" />
    <!-- Change permissions to 777, so everybody can delete / overwrite the lib when building. -->
    <Exec Command="chmod 777 $(OutputPath)libc_wrapper.so" />
  </Target>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('linux'))">
    <ContentWithTargetPath Include="$(OutputPath)libc_wrapper.so">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>libc_wrapper.so</TargetPath>
    </ContentWithTargetPath>
  </ItemGroup>

  <!-- Allow the Unit tests to be able to see internal types. -->
  <ItemGroup>
    <InternalsVisibleTo Include="Duplicati.UnitTest" />
  </ItemGroup>

</Project>
