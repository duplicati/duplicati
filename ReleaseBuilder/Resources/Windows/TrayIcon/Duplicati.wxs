<?xml version="1.0" encoding="UTF-8"?>

<?include UpgradeData.wxi ?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!-- Various nice-to-have shorthands for x64/x32 -->
  <?if $(sys.BUILDARCH) = "x64" ?>
    <?define SystemFolder = "System64Folder" ?>
    <?define SystemFolderX86 = "SystemFolder" ?>
    <?define SoftwareKey = "Software" ?>
    <?define SoftwareKeyX86 = "Software\Wow6432Node" ?>
    <?define ProgramFilesFolder = "ProgramFiles64Folder" ?>
    <?define ProgramFilesFolderX86 = "ProgramFilesFolder" ?>
  <?else?>
    <?define SystemFolder = "SystemFolder" ?>
    <?define SystemFolderX86 = "SystemFolder" ?>
    <?define SoftwareKey = "Software" ?>
    <?define SoftwareKeyX86 = "Software" ?>
    <?define ProgramFilesFolder = "ProgramFilesFolder" ?>
  <?endif?>

  <?define DisplayName = "Duplicati" ?>

  <Product Id="$(var.ProductCode)" Name="$(var.DisplayName)" Language="1033" Version="$(var.ProductVersion)" Manufacturer="$(var.Manufacturer)" UpgradeCode="$(var.UpgradeCode)">
    <Package InstallerVersion="405" Compressed="yes" Id="$(var.PackageCode)" InstallScope="perMachine" />
    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" />

    <!-- Pull in the custom UI flow defined below in the InstallUI fragment. -->
    <UIRef Id="DuplicatiInstallUI" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLLOCATION" />

    <!-- Properties bound to the InstallOptionsDlg checkboxes. -->
    <Property Id="ADD_DESKTOP_SHORTCUT" Value="1" Secure="yes" />
    <Property Id="ADD_PROGRAMMENU_SHORTCUT" Value="1" Secure="yes" />
    <Property Id="ADD_STARTUP_SHORTCUT" Value="1" Secure="yes" />

    <!-- Legacy command-line-only switch. When passed as FORSERVICE=true on the
         msiexec command line it suppresses the shortcut features (Desktop /
         Program Menu / Startup) for unattended/silent service deployments.
         Not exposed in the UI. -->
    <Property Id="FORSERVICE" Value="false" Secure="yes" />

    <!-- Command-line-only switch. When passed as NOSCRIPT=true on the msiexec
         command line it suppresses actions that require a script engine.
         Note that activating this prevents the service install from running.
         Not exposed in the UI. -->
    <Property Id="NOSCRIPT" Value="false" Secure="yes" />

    <!-- Tracks if the TLS certificates feature was selected in the UI or
         passed via command line. Secure="yes" allows it to pass through to
         elevated execution sequence. -->
    <Property Id="INSTALL_TLS_CERTS" Secure="yes">
      <RegistrySearch Id="SearchPreviousInstallCertsForUI"
                      Root="HKLM"
                      Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState"
                      Name="TlsCertsInstalled"
                      Type="raw" />
    </Property>

    <!-- LAUNCH_AS_SERVICE is the UI-side property bound to the
         "Install as Service" checkbox on InstallOptionsDlg. Seeding it
         from the ServiceInstalled marker in InstallState makes the
         checkbox default to checked during a major upgrade when the
         previous version installed the service, preventing the UI
         from silently signalling "remove" on Next-click. -->
    <Property Id="LAUNCH_AS_SERVICE" Secure="yes">
      <RegistrySearch Id="SearchPreviousInstallServiceForUI"
                      Root="HKLM"
                      Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState"
                      Name="ServiceInstalled"
                      Type="raw" />
    </Property>

    <!-- Previous-install detection properties consumed by the uninstall
         custom-action conditions. These mirror the *ForUI searches
         above but are kept as separate properties so the conditional
         logic remains decoupled from the UI checkbox state (which the
         user may toggle). -->
    <Property Id="PREVIOUS_SERVICE_INSTALLED" Secure="yes">
      <RegistrySearch Id="SearchPreviousInstallService"
                      Root="HKLM"
                      Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState"
                      Name="ServiceInstalled"
                      Type="raw" />
    </Property>
    <Property Id="PREVIOUS_CERTS_INSTALLED" Secure="yes">
      <RegistrySearch Id="SearchPreviousInstallCerts"
                      Root="HKLM"
                      Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState"
                      Name="TlsCertsInstalled"
                      Type="raw" />
    </Property>

    <!-- Opt-in commandline switch for installing a preload.json -->
    <Property Id="INSTALL_PRELOAD" Secure="yes" />

    <!-- Property from SetPreloadSource pointing to [SourceDir] -->
    <Property Id="PRELOAD_SOURCE" Secure="yes" />

    <!-- Set to "true" by InstallOptionsDlg when the user opts into installing
         Duplicati as a Windows Service. Currently used only as a UI hint;
         the actual server-side behaviour is driven by the action state of
         DuplicatiServiceFeature (which IS preserved across UAC elevation),
         while the shortcut argument is driven by NOHOSTEDSERVERARG below. -->
    <Property Id="INSTALLASSERVICE" Value="false" Secure="yes" />

    <!-- Random alphanumeric password generated for the service install.
         Generated in the InstallUISequence (client side).
         No default Value: the property must remain undefined for non-service
         installs so the ExitDialog password field does not appear. -->
    <Property Id="DUPLICATI_SERVICE_PASSWORD" Secure="yes" />

    <!-- Redact the password-bearing properties from the verbose MSI log.
         Without this, the "PROPERTY CHANGE: Adding ..." entries would
         expose the password in plaintext when:
           * DUPLICATI_SERVICE_PASSWORD is set by GenerateDuplicatiServicePassword
             and transferred across the UAC elevation boundary, and
           * SetInitPassword (a deferred CA's property of the same name)
             carries the password to the elevated session as part of its
             CustomActionData payload. -->
    <Property Id="MsiHiddenProperties" Value="DUPLICATI_SERVICE_PASSWORD;SetInitPassword" />

    <!-- NOHOSTEDSERVERARG is set at runtime by SetNoHostedServerArg /
         ClearNoHostedServerArg (just before CreateShortcuts). It is consumed
         by the Shortcut.Arguments column via {[NOHOSTEDSERVERARG]} formatting:
         when the property is unset/empty the curly braces collapse and the
         shortcut is created with no arguments. No <Property> default is
         declared because wixl 0.106 rejects Value="" and a non-empty default
         would survive the ClearNoHostedServerArg action. -->

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramMenuFolder" Name="Programs"/>
      <Directory Id="DesktopFolder" Name="Desktop"/>
    
      <Directory Id="$(var.ProgramFilesFolder)">
        <Directory Id="INSTALLLOCATION" Name="Duplicati 2" >
          <Component Id="SecureInstallDirComp" Guid="7C52A563-7182-411E-8B57-79F881775E9B">
              <CreateFolder>
              <!-- WiX supports permssions, wixl uses sql -->
<?if $(var.BuildEnv) = "Windows" ?>
                <util:PermissionEx Sddl="D:P(A;OICI;FA;;;SY)(A;OICI;FA;;;BA)(A;OICI;GRFX;;;BU)" xmlns:util="http://schemas.microsoft.com/wix/UtilExtension"/>
<?endif?>
              </CreateFolder>
          </Component>

          <!-- Always-installed component that owns the Service registry
               key. KeyExists is a stable always-present value used as
               the component's KeyPath so MSI feature-state machinery
               has a deterministic anchor.

               The ACL is applied via WindowsService, because the 
               msi approach has quirks when only locking down parts
               of the key. -->
          <Component Id="DuplicatiServiceKeyComponent" Guid="3C2B1A0F-9E8D-7C6B-5A49-382716054321">
            <RegistryKey Root="HKLM" Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\Service">
              <RegistryValue Id="ServiceKeyHolder" Name="KeyExists" Value="1" Type="string" KeyPath="yes" />
            </RegistryKey>
          </Component>

          <!-- Feature-gated values component for DuplicatiServiceFeature. -->
          <Component Id="DuplicatiServiceFeatureValuesComponent" Guid="6F1E3B8A-2C4D-4F7B-9C5A-3E2D1B0F4A8C">
            <!-- Contributes the feature-gated values:
                   * InstallState\ServiceInstalled - readable persisted
                                                    "feature was installed
                                                    by this MSI" marker
                                                    (the KeyPath for this
                                                    component, so MSI
                                                    feature-state gates
                                                    &amp;Feature /
                                                    !Feature key off it). -->
            <!-- The InstallState key holds:
                   * ServiceInstalled  - readable "feature was installed
                                         by this MSI" marker (KeyPath for
                                         this component)
                   * BootstrapApplied  - sentinel that WindowsService
                                         writes after applying the
                                         password (managed at runtime;
                                         the removal below clears any
                                         stale value at the start of
                                         each install). -->
            <RegistryKey Root="HKLM" Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState">
              <RegistryValue Id="ServiceInstalledMarker"      Name="ServiceInstalled" Value="1" Type="string" KeyPath="yes" />
              <!-- Make sure we remove the BootstrapApplied value if it exists,
                   which is handled by the RemoveRegistry row in
                   InstallTables.sql on non-Windows.
                   The removal is required to ensure we do not pick up a stale value -->
<?if $(var.BuildEnv) = "Windows" ?>
              <RemoveRegistryValue Id="RemoveStaleBootstrapApplied" Name="BootstrapApplied" Action="removeOnInstall" />
<?endif?>
            </RegistryKey>
          </Component>
          <!-- TLS certs marker component. This is used to track if the TLS certs were installed between installer invocations -->
          <Component Id="TlsCertsMarkerComponent" Guid="B8C9D0E1-F2A3-4B5C-6D7E-8F9A0B1C2D3E">
            <RegistryKey Root="HKLM" Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\InstallState">
              <RegistryValue Id="TlsCertsInstalledMarker" Name="TlsCertsInstalled" Value="1" Type="string" KeyPath="yes" />
            </RegistryKey>
            <RegistryKey Root="HKLM" Key="$(var.SoftwareKey)\DuplicatiTeam\Duplicati\Service">
              <RegistryValue Id="TlsCertsOptionValue" Name="TlsCertsOption" Value="install" Type="string" />
            </RegistryKey>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="DuplicatiCore" Level="1" Absent="disallow" ConfigurableDirectory="INSTALLLOCATION" >
      <ComponentRef Id="SecureInstallDirComp" />
      <!-- Always-installed: owns the Service registry key. -->
      <ComponentRef Id="DuplicatiServiceKeyComponent" />
      <ComponentGroupRef Id="DUPLICATIBIN" />
    </Feature>
      
    <Feature Id="DuplicatiDesktopShortCutFeature" Level="1" Absent="allow" AllowAdvertise="no">
      <ComponentRef Id="DuplicatiDesktopShortcutComponent"/>
      <Condition Level="0">FORSERVICE = "true"</Condition>
    </Feature>

    <Feature Id="DuplicatiProgramMenuShortCutFeature" Level="1" Absent="allow" AllowAdvertise="no">
      <ComponentRef Id="DuplicatiProgramMenuShortcutComponent"/>
      <Condition Level="0">FORSERVICE = "true"</Condition>
    </Feature>

    <!-- Install Duplicati as a Windows Service. When selected, the
         TrayIcon shortcut is configured with the no-hosted-server flag so it
         connects to the service.

         Level=2 keeps the feature out of the default install set (the
         default INSTALLLEVEL is 1). The InstallOptionsDlg.Next button
         publishes AddLocal DuplicatiServiceFeature when the user checks the
         service box, which adds it to ADDLOCAL and overrides the Level
         exclusion. Without that AddLocal, the feature stays absent. -->
    <Feature Id="DuplicatiServiceFeature" Level="2" Absent="allow" AllowAdvertise="no">
      <ComponentRef Id="DuplicatiServiceFeatureValuesComponent"/>
    </Feature>
    
    <Feature Id="DuplicatiTlsCertsFeature" Level="2" Absent="allow" AllowAdvertise="no">
      <ComponentRef Id="TlsCertsMarkerComponent"/>
    </Feature>

    <Feature Id="DuplicatiStartupShortCutFeature" Level="1" Absent="allow" AllowAdvertise="no">
      <ComponentRef Id="StartupMenuItem"/>
      <Condition Level="0">FORSERVICE = "true"</Condition>
    </Feature>

    <!-- Launch duplicati setup -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Duplicati now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <!-- Two LaunchApplication variants:
           * LaunchApplication           - the standard non-service launch.
                                           No arguments; the TrayIcon hosts
                                           its own server.
           * LaunchApplicationNoHosted   - service-mode launch with
                                           no-hosted-server so the
                                           TrayIcon connects to the
                                           Duplicati Windows Service.
         The ExitDialog Finish button picks between
         them via Publish conditions keyed on the service feature's
         action state (&amp;DuplicatiServiceFeature=3) -->
    <CustomAction Id="LaunchApplication"          FileKey="Duplicati.GUI.TrayIcon.exe" Impersonate="yes" ExeCommand=""                    Return="asyncNoWait" />
    <CustomAction Id="LaunchApplicationNoHosted"  FileKey="Duplicati.GUI.TrayIcon.exe" Impersonate="yes" ExeCommand="--no-hosted-server"  Return="asyncNoWait" />
    
    <!-- Set the Add/Remove icon -->
    <Property Id="ARPPRODUCTICON" Value="DuplicatiIcon.exe" />

    <!-- Remove old versions -->
    <InstallExecuteSequence>
      <!-- Note: This is suboptimal, but the ref counting is not working, so we use Early REP -->
      <RemoveExistingProducts After="FindRelatedProducts" />

      <!-- Check service status early (immediate action, can run anytime) -->
      <Custom Action="CheckService" After="FindRelatedProducts">NOSCRIPT &lt;&gt; "true" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <!-- Stop and start service must be deferred actions between InstallInitialize and InstallFinalize -->
      <Custom Action="StopService" After="InstallInitialize">SERVICE_WAS_STOPPED=1 AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="StartService" After="InstallFiles">SERVICE_WAS_STOPPED=1 AND NOT REMOVE~="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>

      <!-- Set NOHOSTEDSERVERARG so the shortcut Arguments column expands to
           the no-hosted-server flag when the service feature ends up
           installed locally, and to empty otherwise. The Shortcut.Arguments
           column is a Formatted string and uses {[NOHOSTEDSERVERARG]} so an
           empty value produces no arguments at all.
           Must run before CreateShortcuts (4500). -->
      <Custom Action="SetNoHostedServerArg"   Before="CreateShortcuts">&amp;DuplicatiServiceFeature=3</Custom>
      <Custom Action="ClearNoHostedServerArg" Before="CreateShortcuts">NOT (&amp;DuplicatiServiceFeature=3)</Custom>

      <!-- Resolves [SourceDir] into PRELOAD_SOURCE -->
      <Custom Action="SetPreloadSource" After="CostFinalize">INSTALL_PRELOAD="true" AND NOT Installed</Custom>

      <!--
        Service install pipeline (only when the service feature is being
        installed, gated by the same condition):
          1. Generate random password into DUPLICATI_SERVICE_PASSWORD
          2. LockServiceRegKey so we are sure the key is protected
             even if it is not used in this install sequence.
          3. SetInitPassword also recreates the key
          4. InstallDuplicatiService (after InitPassword)
          5. After ExecuteAction returns to the UI sequence and 
             CheckBootstrapResult polls for the applied password.
          6. If password was applied, store password in user's keyring.
      -->
      <Custom Action="GenerateDuplicatiServicePassword" Sequence="1505">(&amp;DuplicatiServiceFeature=3) AND (!DuplicatiServiceFeature&lt;&gt;3) AND NOT UPGRADINGPRODUCTCODE AND NOSCRIPT &lt;&gt; "true" AND UILevel &gt;= 5</Custom>

      <!-- Ensure the service key is always locked down. -->
      <Custom Action="SetLockServiceRegKey" Sequence="4798">(&amp;DuplicatiCore=3) AND NOT UPGRADINGPRODUCTCODE AND NOSCRIPT &lt;&gt; "true" AND NOT REMOVE~="ALL"</Custom>
      <Custom Action="LockServiceRegKey"    Sequence="4800">(&amp;DuplicatiCore=3) AND NOT UPGRADINGPRODUCTCODE AND NOSCRIPT &lt;&gt; "true" AND NOT REMOVE~="ALL"</Custom>

      <!-- Atomic set InitPassword. -->
      <Custom Action="SetSetInitPassword" Sequence="4899">(&amp;DuplicatiServiceFeature=3) AND DUPLICATI_SERVICE_PASSWORD AND NOT UPGRADINGPRODUCTCODE AND NOSCRIPT &lt;&gt; "true" AND NOT REMOVE~="ALL"</Custom>
      <Custom Action="SetInitPassword"    Sequence="4900">(&amp;DuplicatiServiceFeature=3) AND DUPLICATI_SERVICE_PASSWORD AND NOT UPGRADINGPRODUCTCODE AND NOSCRIPT &lt;&gt; "true" AND NOT REMOVE~="ALL"</Custom>

      <!-- Sequence 5500 puts InstallDuplicatiService after both the
           standard WriteRegistryValues (5000) and the SetInitPassword CA
           (4900), so InitPassword is already in the locked-down Service
           key by the time SCM registers and starts the service. -->
      <Custom Action="SetInstallDuplicatiService" Sequence="5499">(&amp;DuplicatiServiceFeature=3) AND (!DuplicatiServiceFeature&lt;&gt;3) AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="InstallDuplicatiService" Sequence="5500">(&amp;DuplicatiServiceFeature=3) AND (!DuplicatiServiceFeature&lt;&gt;3) AND NOT UPGRADINGPRODUCTCODE</Custom>

      <Custom Action="SetInstallTlsCertsUser" Sequence="5501">(&amp;DuplicatiTlsCertsFeature=3) AND (!DuplicatiServiceFeature&lt;&gt;3) AND (&amp;DuplicatiServiceFeature&lt;&gt;3) AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="InstallTlsCertsUser" Sequence="5502">(&amp;DuplicatiTlsCertsFeature=3) AND (!DuplicatiServiceFeature&lt;&gt;3) AND (&amp;DuplicatiServiceFeature&lt;&gt;3) AND NOT UPGRADINGPRODUCTCODE</Custom>

      <!--
        TLS cert uninstall has two variants picked by whether the service
        was present:
          * UninstallTlsCertsUser    - runs when service was NOT present
          * UninstallTlsCertsService - runs when service WAS present
        The PREVIOUS_*_INSTALLED clauses handle the major-upgrade case
        symmetrically with the service uninstall logic above. The
        negated service-presence expression
            NOT (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED="1")
        means "service was neither installed by this MSI nor by a
        previous install", routing cleanup through the user-mode path.
      -->
      <!-- These run AFTER InstallFiles so we always use the latest version,
        instead of the previous version's binaries.
      -->
      <Custom Action="SetUninstallTlsCertsUser" Before="UninstallTlsCertsUser">(&amp;DuplicatiTlsCertsFeature&lt;&gt;3) AND (!DuplicatiTlsCertsFeature=3 OR PREVIOUS_CERTS_INSTALLED=&quot;1&quot;) AND NOT (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="UninstallTlsCertsUser" After="InstallFiles">(&amp;DuplicatiTlsCertsFeature&lt;&gt;3) AND (!DuplicatiTlsCertsFeature=3 OR PREVIOUS_CERTS_INSTALLED=&quot;1&quot;) AND NOT (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>

      <!-- InstallTlsCertsService is done in the service, so we just also
           use the service binary to remove the cert data . -->
      <Custom Action="SetUninstallTlsCertsService" Before="UninstallTlsCertsService">(&amp;DuplicatiTlsCertsFeature&lt;&gt;3) AND (!DuplicatiTlsCertsFeature=3 OR PREVIOUS_CERTS_INSTALLED=&quot;1&quot;) AND (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="UninstallTlsCertsService" After="InstallFiles">(&amp;DuplicatiTlsCertsFeature&lt;&gt;3) AND (!DuplicatiTlsCertsFeature=3 OR PREVIOUS_CERTS_INSTALLED=&quot;1&quot;) AND (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>

      <!-- Uninstall the Windows Service before files are removed.
           Runs when the service feature was previously installed and is being
           removed (full uninstall or feature deselect via reconfigure). -->
      <!--
        The PREVIOUS_SERVICE_INSTALLED="1" clause handles the major-upgrade
        case where !DuplicatiServiceFeature=3 is always false (the new
        ProductCode has never been installed). Without it, the new MSI
        would never take responsibility for cleaning up service state
        that the old MSI skipped because UPGRADINGPRODUCTCODE was set.
      -->
      <Custom Action="SetUninstallDuplicatiService" Before="UninstallDuplicatiService">(&amp;DuplicatiServiceFeature&lt;&gt;3) AND (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="UninstallDuplicatiService" Before="RemoveFiles">(&amp;DuplicatiServiceFeature&lt;&gt;3) AND (!DuplicatiServiceFeature=3 OR PREVIOUS_SERVICE_INSTALLED=&quot;1&quot;) AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <!-- Post-ExecuteAction client-side actions:
         CheckBootstrapResult polls for the BootstrapApplied registry sentinel
         that ServiceControl writes once Duplicati.Server.exe has consumed
         InitPassword and committed the password to the database. On timeout
         it clears DUPLICATI_SERVICE_PASSWORD, hiding the ExitDialog password
         panel.
         StoreTrayIconValues then runs - immediate, in the UI process which
         already runs as the installing user, no impersonation dance needed.
         Its condition checks DUPLICATI_SERVICE_PASSWORD so it only fires
         when CheckBootstrapResult confirmed success. -->
    <InstallUISequence>
      <Custom Action="GenerateDuplicatiServicePassword" Sequence="1100">NOT Installed AND &amp;DuplicatiServiceFeature=3</Custom>
      <Custom Action="CheckBootstrapResult"             Sequence="1305">DUPLICATI_SERVICE_PASSWORD</Custom>
      <Custom Action="StoreTrayIconValues"              Sequence="1306">DUPLICATI_SERVICE_PASSWORD</Custom>
    </InstallUISequence>

    <Property Id="PREVIOUSVERSIONSINSTALLED" Secure="yes" />
    <Upgrade Id="$(var.UpgradeCode)">
      <UpgradeVersion Minimum="2.0.0.0" Property="PREVIOUSVERSIONSINSTALLED"  Maximum="99.0.0.0" IncludeMinimum="yes" IncludeMaximum="no" />
    </Upgrade>

    <Icon Id="DuplicatiIcon.exe" SourceFile="$(var.HarvestPath)Duplicati.GUI.TrayIcon.exe" />
    
    <!-- Service restart code below -->
    <Binary Id="CheckServiceScript" SourceFile="CheckService.js" />
    <Binary Id="StopServiceScript"  SourceFile="StopService.js" />
    <Binary Id="StartServiceScript" SourceFile="StartService.js" />

    <!-- Random password generation + service configuration scripts. -->
    <Binary Id="GeneratePasswordScript"          SourceFile="GeneratePassword.js" />
    <Binary Id="StoreTrayIconValuesScript"       SourceFile="StoreTrayIconValues.js" />
    <Binary Id="CheckBootstrapResultScript"      SourceFile="CheckBootstrapResult.js" />
    <Binary Id="CopyPasswordToClipboardScript"   SourceFile="CopyPasswordToClipboard.js" />
    <Binary Id="SilentRunScript"                 SourceFile="SilentRun.js" />
    <Binary Id="SetInitPasswordScript"           SourceFile="SetInitPassword.js" />

    <CustomAction Id="CheckService"
              BinaryKey="CheckServiceScript"
              JScriptCall="CustomAction"
              Execute="immediate"
              Return="ignore" />

    <CustomAction Id="StopService"
              BinaryKey="StopServiceScript"
              JScriptCall="CustomAction"
              Execute="deferred"
              Impersonate="no"
              Return="ignore" />

    <CustomAction Id="StartService"
              BinaryKey="StartServiceScript"
              JScriptCall="CustomAction"
              Execute="deferred"
              Return="check" />

    <!-- Type-51 SetProperty custom actions used to populate NOHOSTEDSERVERARG
         in the InstallExecuteSequence (just before CreateShortcuts) based on
         the service feature's action state. The value flows into the Shortcut
         table's Arguments column via {[NOHOSTEDSERVERARG]} formatted-string
         substitution. -->
    <CustomAction Id="SetNoHostedServerArg"
              Property="NOHOSTEDSERVERARG"
              Value="--no-hosted-server"
              Execute="immediate"
              Return="check" />

    <CustomAction Id="ClearNoHostedServerArg"
              Property="NOHOSTEDSERVERARG"
              Value=""
              Execute="immediate"
              Return="check" />

    <!-- Resolves [SourceDir] into the PRELOAD_SOURCE property -->
    <CustomAction Id="SetPreloadSource"
              Property="PRELOAD_SOURCE"
              Value="[SourceDir]"
              Execute="immediate"
              Return="check" />

    <!-- Service install/uninstall custom actions.
         The installer invokes Duplicati.WindowsService.exe via a JScript
         helper (SilentRun.js) so the console window stays hidden.
         The command line is passed through CustomActionData using a pair
         of Type-51 SetProperty actions. -->
    <CustomAction Id="SetInstallDuplicatiService"
              Property="InstallDuplicatiService"
              Value="&quot;[#Duplicati.WindowsService.exe]&quot; INSTALL"
              Execute="immediate"
              Return="check" />

    <CustomAction Id="SetUninstallDuplicatiService"
              Property="UninstallDuplicatiService"
              Value="&quot;[#Duplicati.WindowsService.exe]&quot; UNINSTALL"
              Execute="immediate"
              Return="check" />

    <!-- Locks down the Service registry key DACL via
         Duplicati.WindowsService.exe lock-service-key. See the comment block
         in InstallExecuteSequence above the action call for the
         scheduling rationale. -->
    <CustomAction Id="SetLockServiceRegKey"
              Property="LockServiceRegKey"
              Value="&quot;[#Duplicati.WindowsService.exe]&quot; lock-service-key"
              Execute="immediate"
              Return="check" />

    <CustomAction Id="LockServiceRegKey"
              BinaryKey="SilentRunScript"
              JScriptCall="RunAppHidden"
              Execute="deferred"
              Impersonate="no"
              Return="check" />

    <!-- Type-51 SetProperty that hands the password and the path to
         Duplicati.WindowsService.exe to the deferred SetInitPassword CA
         below.

         CRITICAL: the property name 'SetInitPassword' is listed in
         MsiHiddenProperties above so the password value is redacted in
         the verbose MSI log. -->
    <CustomAction Id="SetSetInitPassword"
              Property="SetInitPassword"
              Value="[#Duplicati.WindowsService.exe]|[DUPLICATI_SERVICE_PASSWORD]"
              Execute="immediate"
              Return="check" />

    <!-- Service install/uninstall custom actions. -->
    <CustomAction Id="InstallDuplicatiService"
              BinaryKey="SilentRunScript"
              JScriptCall="RunAppHidden"
              Execute="deferred"
              Impersonate="no"
              Return="check" />

    <CustomAction Id="UninstallDuplicatiService"
              BinaryKey="SilentRunScript"
              JScriptCall="RunAppHidden"
              Execute="deferred"
              Impersonate="no"
              Return="ignore" />

    <!-- Sets the initial password for the webservice. -->
    <CustomAction Id="SetInitPassword"
              BinaryKey="SetInitPasswordScript"
              JScriptCall="RunSetInitPassword"
              Execute="deferred"
              Impersonate="no"
              Return="check" />

    <CustomAction Id="SetInstallTlsCertsUser" Property="InstallTlsCertsUser" Value="&quot;[#Duplicati.CommandLine.ConfigureTool.exe]&quot; https generate --auto-create-database" Execute="immediate" Return="check" />
    <CustomAction Id="InstallTlsCertsUser" BinaryKey="SilentRunScript" JScriptCall="RunAppHidden" Execute="deferred" Impersonate="yes" Return="ignore" />

    <CustomAction Id="SetUninstallTlsCertsUser" Property="UninstallTlsCertsUser" Value="&quot;[#Duplicati.CommandLine.ConfigureTool.exe]&quot; https remove" Execute="immediate" Return="check" />
    <CustomAction Id="UninstallTlsCertsUser" BinaryKey="SilentRunScript" JScriptCall="RunAppHidden" Execute="deferred" Impersonate="yes" Return="ignore" />

    <CustomAction Id="SetUninstallTlsCertsService" Property="UninstallTlsCertsService" Value="&quot;[#Duplicati.WindowsService.exe]&quot; remove-certs" Execute="immediate" Return="check" />
    <CustomAction Id="UninstallTlsCertsService" BinaryKey="SilentRunScript" JScriptCall="RunAppHidden" Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Generates the random password and stores it in
         DUPLICATI_SERVICE_PASSWORD. Immediate so the property is set before
         the SetCustomActionData type-51 actions read it. -->
    <CustomAction Id="GenerateDuplicatiServicePassword"
              BinaryKey="GeneratePasswordScript"
              JScriptCall="CustomAction"
              Execute="immediate"
              Return="check" />

    <!-- Runs in the InstallUISequence after ExecuteAction. Polls the
         registry for the BootstrapApplied sentinel and clears
         DUPLICATI_SERVICE_PASSWORD client-side if the sentinel does not
         appear within the script's timeout, which hides the password panel
         on the ExitDialog. -->
    <CustomAction Id="CheckBootstrapResult"
              BinaryKey="CheckBootstrapResultScript"
              JScriptCall="CustomAction"
              Execute="immediate"
              Return="ignore" />

    <!-- Immediate CA in the InstallUISequence, sequenced AFTER
         CheckBootstrapResult so it can rely on CheckBootstrapResult having
         cleared DUPLICATI_SERVICE_PASSWORD on bootstrap failure. Reads the
         password and the SecretTool path directly from session properties.
         The UI sequence runs as the installing user (un-elevated), which is
         exactly the context where the user credential vault entry needs to
         be written, so no Impersonate dance is needed. -->
    <CustomAction Id="StoreTrayIconValues"
              BinaryKey="StoreTrayIconValuesScript"
              JScriptCall="CustomAction"
              Execute="immediate"
              Return="ignore" />

    <!-- Wired to the "Copy" button on the ExitDialog. Immediate so it can
         read DUPLICATI_SERVICE_PASSWORD directly from the session. -->
    <CustomAction Id="CopyServicePasswordToClipboard"
              BinaryKey="CopyPasswordToClipboardScript"
              JScriptCall="CustomAction"
              Execute="immediate"
              Return="ignore" />

  </Product>

  <!--
    Custom UI flow for the Duplicati installer.

    Dialog sequence on a fresh install:
       WelcomeDlg -> LicenseAgreementDlg -> InstallOptionsDlg -> VerifyReadyDlg -> ProgressDlg -> ExitDialog

    Maintenance:
       MaintenanceWelcomeDlg -> MaintenanceTypeDlg
         + Change   -> InstallOptionsDlg -> VerifyReadyDlg
         + Repair   -> VerifyReadyDlg
         + Remove   -> VerifyReadyDlg

    InstallOptionsDlg replaces the standard CustomizeDlg with a simple checkbox dialog
    (defined in the InstallOptionsDlg.wxs fragment). The checkboxes drive
    the LAUNCH_AS_SERVICE / ADD_*_SHORTCUT properties, which are translated into
    feature AddLocal/Remove publishes when the user clicks Next.
  -->
  <Fragment>
    <UI Id="DuplicatiInstallUI">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode" Value="InstallDir" />

      <DialogRef Id="BrowseDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="InstallOptionsDlg" />

      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="LicenseAgreementDlg" Condition="NOT Installed" />
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="Installed AND PATCH" />

      <Publish Dialog="LicenseAgreementDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" />
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="InstallOptionsDlg" Condition="LicenseAccepted = &quot;1&quot;" />

      <!-- The Next button on InstallOptionsDlg also publishes AddLocal/Remove events
           and the SetTargetPath/FORSERVICE property. Those are defined on the dialog
           itself; here we only define the navigation. -->
      <Publish Dialog="InstallOptionsDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg" Order="1" Condition="NOT Installed" />
      <Publish Dialog="InstallOptionsDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg"   Order="2" Condition="Installed" />
      <Publish Dialog="InstallOptionsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg"      Order="100" />

      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="InstallOptionsDlg"   Order="1" Condition="NOT Installed OR WixUI_InstallMode = &quot;Change&quot;" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2" Condition="Installed AND NOT PATCH" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg"          Order="3" Condition="Installed AND PATCH" />

      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />

      <Publish Dialog="MaintenanceTypeDlg" Control="ChangeButton" Event="NewDialog" Value="InstallOptionsDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="Back"         Event="NewDialog" Value="MaintenanceWelcomeDlg" />
    </UI>

    <UIRef Id="WixUI_Common" />
  </Fragment>
</Wix>
